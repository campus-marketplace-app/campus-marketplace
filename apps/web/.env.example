# Frontend Environment Variables
# Copy this file to .env.local and fill in with your actual values

# School code identifier (used to fetch theme from school_themes table)
VITE_SCHOOL_CODE=184782

# Optional: Supabase URLs for reference (frontend should NOT use these directly)
# These are only for documentation. Frontend calls backend services instead.
# VITE_SUPABASE_URL=your-supabase-url
# VITE_SUPABASE_ANON_KEY=your-supabase-anon-key
