# Frontend Environment Variables
# Copy this file to .env.local and fill in with your actual values

# School code identifier — integer IPEDS OPE ID (used to fetch theme from school_themes table)
# NJIT = 184782
VITE_SCHOOL_CODE=184782

# Required: Supabase credentials for the browser-side Supabase client
# The frontend bundles the backend service layer, which reads these at runtime.
# Use the anon (public) key — never the service key in the browser.
VITE_SUPABASE_URL=your-supabase-url
VITE_SUPABASE_ANON_KEY=your-supabase-anon-key
